# Azure OpenAI (obligatorio para el chat)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Debe ser un deployment con visión (p. ej. gpt-4o) para analizar capturas de error.
AZURE_OPENAI_DEPLOYMENT_NAME=tu-deployment

# API (Render inyecta PORT; no hace falta en producción)
PORT=8787

# Tickets: solo con `true` se crean desde el chat/API. Si no está o es false, el asistente guía con plantilla HelpDesk.
TICKETS_FROM_PORTAL_ENABLED=false

# URL completa del reproductor Power Apps (HelpDesk). Sin esto no aparece el botón hacia HelpDesk.
# Por defecto el servidor NO añade Titulo, Descripcion, etc. a la query (solo abre la app; el usuario copia los campos en la UI).
# Para precargar el formulario vía URL más adelante: HELPDESK_URL_QUERY_PARAMS_ENABLED=true
# (y en Power Apps leer Param("Titulo"), Param("Descripcion"), … — ver server/src/helpdeskTemplate.ts).
# HELPDESK_URL_PARAM_TITULO=MiTitulo  # opcional si los nombres de parámetro difieren
# Ejemplo (puede incluir tenantId/hint en la propia URL fija del portal):
HELPDESK_POWERAPPS_URL=https://apps.powerapps.com/play/e/98169ae5-52be-e43c-aed8-03a24eb7bae6/a/ad70cf6b-2b51-45b2-95de-a4e97a72bbf9?tenantId=e1bdfea1-5fcd-44c1-8196-dfa7afddd8c5&hint=fc02eef7-48e3-42fa-acf3-61a0bc5c959a&source=portal
# HELPDESK_URL_QUERY_PARAMS_ENABLED=false

# Despliegue: en Render use el Blueprint del archivo render.yaml en la raíz del repo
# y defina las variables secretas (Azure OpenAI, correo, etc.) en el panel o al aplicar el Blueprint.

# Correo al crear ticket (destino por defecto: angiepena@cbit-online.com si no se define)
TICKET_NOTIFY_EMAIL=angiepena@cbit-online.com

# Opción A — Resend (recomendado para pruebas): https://resend.com — API key y remitente verificado
# Si RESEND_API_KEY está definida, se usa antes que SMTP.
RESEND_API_KEY=
# Ejemplo con dominio verificado en Resend: "Mesa Periferia <avisos@tudominio.com>"
RESEND_FROM=

# Opción B — SMTP (p. ej. Microsoft 365): smtp.office365.com, puerto 587, usuario = correo completo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
