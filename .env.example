# Azure OpenAI (obligatorio para el chat)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Debe ser un deployment con visión (p. ej. gpt-4o) para analizar capturas de error.
AZURE_OPENAI_DEPLOYMENT_NAME=tu-deployment

# API (Render inyecta PORT; no hace falta en producción)
PORT=8787

# Despliegue: en Render use el Blueprint del archivo render.yaml en la raíz del repo
# y defina las variables secretas (Azure OpenAI, correo, etc.) en el panel o al aplicar el Blueprint.

# Correo al crear ticket (destino por defecto: angiepena@cbit-online.com si no se define)
TICKET_NOTIFY_EMAIL=angiepena@cbit-online.com

# Opción A — Resend (recomendado para pruebas): https://resend.com — API key y remitente verificado
# Si RESEND_API_KEY está definida, se usa antes que SMTP.
RESEND_API_KEY=
# Ejemplo con dominio verificado en Resend: "Mesa Periferia <avisos@tudominio.com>"
RESEND_FROM=

# Opción B — SMTP (p. ej. Microsoft 365): smtp.office365.com, puerto 587, usuario = correo completo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
