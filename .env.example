# Azure OpenAI (obligatorio para el chat)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Debe ser un deployment con visión (p. ej. gpt-4o) para analizar capturas de error.
# Acepta AZURE_OPENAI_DEPLOYMENT o AZURE_OPENAI_DEPLOYMENT_NAME.
AZURE_OPENAI_DEPLOYMENT=tu-deployment

# API (Render inyecta PORT; no hace falta en producción)
PORT=8787

# Tickets: con `true` se crean en archivo local. Si SharePoint está configurado abajo, también se habilitan tickets desde el chat.
TICKETS_FROM_PORTAL_ENABLED=false

# Login Microsoft al abrir el chatbot (desde Power Apps u otro portal).
# En Azure AD → App registration → Authentication → Add platform «Single-page application»:
#   Redirect URI: http://localhost:5173/  y https://tu-dominio-produccion/
# (debe coincidir exactamente, con barra final). Permiso delegado: User.Read + consentimiento admin.
# Si el login abre otra pestaña sin autenticar, suele faltar la plataforma SPA o el redirect URI.
# AZURE_AUTH_ENABLED=false  # desactiva MSAL aunque haya tenant/client id
# AZURE_CLIENT_ID=          # opcional; si no se define, se usa SHAREPOINT_CLIENT_ID

# SharePoint — lista RPA_SOLICITUD_TICKET_SOPORTE (creación de tickets con IA cuando no hay FAQ)
# Requiere app registration en Azure AD con permiso Sites.ReadWrite.All (o Sites.Selected en esa lista).
AZURE_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_URL=https://periferiaitgroup.sharepoint.com/sites/Infraestructura
SHAREPOINT_LIST_NAME=RPA_SOLICITUD_TICKET_SOPORTE
# Opcional: URL directa a la vista de la lista (si difiere de la generada automáticamente)
# SHAREPOINT_LIST_URL=https://periferiaitgroup.sharepoint.com/sites/Infraestructura/Lists/RPA_SOLICITUD_TICKET_SOPORTE/AllItems.aspx
# Texto de origen que se incluye en Descripcion (la lista no tiene columna Origen)
# SHAREPOINT_SOURCE_VALUE=Chatbot IA — Mesa Servicios
# Estado inicial (lookup): 1=Abierto, 6=Asignado a técnico
# SHAREPOINT_ESTADO_LOOKUP_ID=1
# Nombres internos de columnas SharePoint (ajustar solo si difieren):
# SHAREPOINT_FIELD_DESCRIPTION=Descripcion
# SHAREPOINT_FIELD_REQUESTER_TEXT=SolicitadoPorTexto
# SHAREPOINT_FIELD_REQUESTER_LOOKUP=SolicitadoPorLookupId
# MSAL (frontend): permisos delegados User.Read + Sites.ReadWrite.All + {SHAREPOINT_HOST}/AllSites.Write
# (consentimiento de admin en Entra ID) para rellenar «Solicitado Por» (persona).
# SHAREPOINT_FIELD_CATEGORY_TEXT=CategoriaTexto
# SHAREPOINT_FIELD_PRIORITY_LOOKUP=PrioridadLookupId
# SHAREPOINT_FIELD_CATEGORY_LOOKUP=CategoriaLookupId
# SHAREPOINT_FIELD_STATUS_LOOKUP=EstadoLookupId

# URL completa del reproductor Power Apps (HelpDesk). Sin esto no aparece el botón hacia HelpDesk.
# Por defecto el servidor NO añade Titulo, Descripcion, etc. a la query (solo abre la app; el usuario copia los campos en la UI).
# Para precargar el formulario vía URL más adelante: HELPDESK_URL_QUERY_PARAMS_ENABLED=true
# (y en Power Apps leer Param("Titulo"), Param("Descripcion"), … — ver server/src/helpdeskTemplate.ts).
# HELPDESK_URL_PARAM_TITULO=MiTitulo  # opcional si los nombres de parámetro difieren
# Ejemplo (puede incluir tenantId/hint en la propia URL fija del portal):
HELPDESK_POWERAPPS_URL=https://apps.powerapps.com/play/e/98169ae5-52be-e43c-aed8-03a24eb7bae6/a/ad70cf6b-2b51-45b2-95de-a4e97a72bbf9?tenantId=e1bdfea1-5fcd-44c1-8196-dfa7afddd8c5&hint=fc02eef7-48e3-42fa-acf3-61a0bc5c959a&source=portal
# HELPDESK_URL_QUERY_PARAMS_ENABLED=false

# Despliegue: en Render use el Blueprint del archivo render.yaml en la raíz del repo
# y defina las variables secretas (Azure OpenAI, correo, etc.) en el panel o al aplicar el Blueprint.

# Correo al crear ticket (destino por defecto: angiepena@cbit-online.com si no se define)
TICKET_NOTIFY_EMAIL=angiepena@cbit-online.com

# Opción A — Resend (recomendado para pruebas): https://resend.com — API key y remitente verificado
# Si RESEND_API_KEY está definida, se usa antes que SMTP.
RESEND_API_KEY=
# Ejemplo con dominio verificado en Resend: "Mesa Periferia <avisos@tudominio.com>"
RESEND_FROM=

# Opción B — SMTP (p. ej. Microsoft 365): smtp.office365.com, puerto 587, usuario = correo completo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
